{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://techsapo.dev/schemas/adapter-preset-matrix.schema.json",
  "title": "AdapterPresetMatrix",
  "description": "Open map: adapterId → preset → catalog model id. New adapters (native or routed) add keys under adapters without schema migration.",
  "type": "object",
  "required": ["version", "adapters"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "pattern": "^[0-9]+$" },
    "description": { "type": "string" },
    "constitutionPeerAdapters": {
      "type": "array",
      "description": "Wall-Bounce peer adapters that must expose all four presets (Track C enforce). Optional adapters omit this list.",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "adapters": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/presetMap" }
    }
  },
  "$defs": {
    "presetMap": {
      "type": "object",
      "required": ["fast", "balanced", "deep", "critical"],
      "additionalProperties": false,
      "properties": {
        "fast": { "type": "string", "minLength": 1 },
        "balanced": { "type": "string", "minLength": 1 },
        "deep": { "type": "string", "minLength": 1 },
        "critical": { "type": "string", "minLength": 1 }
      }
    }
  }
}
