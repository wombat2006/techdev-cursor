            "notes": { "type": "string" }
          }
        },
        "serverSideCompaction": {
          "type": "object",
          "additionalProperties": false,
          "description": "Platform compaction API — 4.6+; 4.5 uses SDK cookbook path",
          "properties": {
            "supported": { "type": "boolean" },
            "notes": { "type": "string" }
          }
        }
      }
    },
    "builtinTools": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mcp": { "type": "boolean" },
        "computerUse": { "type": "boolean" },
        "webSearch": { "type": "boolean" },
        "fileSearch": { "type": "boolean" },
        "codeInterpreter": { "type": "boolean" },
        "customTool": { "type": "boolean" },
        "terminal": { "type": "boolean" },
        "applyPatch": { "type": "boolean" }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reasoning": {
          "type": "string",
          "enum": ["minimal", "low", "medium", "high", "frontier"]
        },
        "toolUse": { "type": "boolean" },
        "toolSearch": { "type": "boolean" },
        "computerUse": { "type": "boolean" },
        "compaction": { "type": "boolean" },
        "multimodal": { "type": "boolean" },
        "japaneseQuality": {
          "type": "string",
          "enum": ["unknown", "fair", "good", "excellent"]
        },
        "codegen": { "type": "boolean" },
        "longWorkflow": { "type": "boolean" },
        "spatialReasoning": { "type": "boolean" },
        "documentUnderstanding": { "type": "boolean" },
        "imageUnderstanding": { "type": "boolean" }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contextTokens": { "type": "integer", "minimum": 1 },
        "maxOutputTokens": { "type": "integer", "minimum": 1 },
        "pricingContextNote": {
          "type": "string",
          "description": "Pricing tier qualifier (e.g. <272K context length)"
        }
      }
    },
    "tokenPricingRates": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "inputUsd": { "type": "number", "minimum": 0 },
        "cachedInputUsd": { "type": "number", "minimum": 0 },
        "outputUsd": { "type": "number", "minimum": 0 }
      }
    },
    "apiPricing": {
      "type": "object",
      "additionalProperties": false,
      "description": "OpenAI / Anthropic API token pricing (USD per 1M tokens) — for cost-aware routing",
      "properties": {
        "currency": { "type": "string", "enum": ["USD"] },
        "unit": { "type": "string", "enum": ["per_1m_tokens"] },
        "lastReviewed": { "type": "string", "format": "date" },
        "pricingUrl": { "type": "string", "format": "uri" },
        "standard": { "$ref": "#/$defs/tokenPricingRates" },
        "batch": { "$ref": "#/$defs/tokenPricingRates" },
        "flex": { "$ref": "#/$defs/tokenPricingRates" },
        "priority": { "$ref": "#/$defs/tokenPricingRates" }
      }
    },
    "transport": {
      "type": "object",
      "required": ["invocationTypes"],
      "additionalProperties": false,
      "properties": {
        "invocationTypes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["claude_cli", "codex_cli", "agy_cli", "responses_api", "openai_sdk", "anthropic_sdk", "openrouter"]
          }
        },
        "preferredInvocation": {
          "type": "string",
          "enum": ["claude_cli", "codex_cli", "agy_cli", "responses_api", "openai_sdk", "anthropic_sdk", "openrouter"]
        },
        "apiSurface": {
          "type": "string",
          "enum": ["responses_api", "chat_completions", "cli_only"]
        },
        "nativeModelFlag": {
          "type": "string",
          "description": "CLI/API model id only (e.g. gpt-5.5, sonnet) — not full invocation recipe"
        },
        "invocationBindingRef": {
          "type": "string",
          "description": "Optional pointer to adapter binding implementation (e.g. openai:codex-exec-v1). Args/body live in code, not catalog."
        }
      }
    },
    "modelEntry": {
      "type": "object",
      "required": ["id", "vendor", "displayName", "status", "tier", "capabilities", "transport"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "vendor": { "type": "string", "minLength": 1 },
        "modelFamily": {
          "type": "string",
          "description": "Vendor model generation line (gpt-5.5, gpt-5.4, gpt-5-codex, claude-sonnet-4, …)"
        },
        "displayName": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["active", "planned", "deprecated"]
        },
        "replaces": { "type": "string" },
        "deprecatedBy": { "type": "string" },
        "tier": { "type": "number", "minimum": 0, "maximum": 5 },
        "roles": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "llm_analyze",
              "llm_codegen",
              "llm_agent_edit",
              "llm_cross_critique",
              "llm_aggregate",
              "grounding_fetch",
              "embedding"
            ]
          }
        },
        "modalities": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/modality" }
        },
        "presetDefault": {
          "type": "string",
          "enum": ["fast", "balanced", "deep", "critical"]
        },
        "prompting": { "$ref": "#/$defs/promptingProfile" },
        "capabilities": { "$ref": "#/$defs/capabilities" },
        "builtinTools": { "$ref": "#/$defs/builtinTools" },
        "apiFeatures": { "$ref": "#/$defs/apiFeatures" },
        "limits": { "$ref": "#/$defs/limits" },
        "transport": { "$ref": "#/$defs/transport" },
        "references": {
          "type": "array",
          "items": { "$ref": "#/$defs/reference" }
        },
        "costHint": {
          "type": "string",
          "enum": ["nano", "mini", "standard", "flagship", "frontier"]
        },
        "apiPricing": { "$ref": "#/$defs/apiPricing" },
        "notes": { "type": "string" },
        "escalation": {
          "type": "object",
          "required": ["targetModelId"],
          "additionalProperties": false,
          "properties": {
            "targetModelId": { "type": "string", "minLength": 1 },
            "confidenceBelow": { "type": "number", "minimum": 0, "maximum": 1 },
            "peerConsensusBelow": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      }
    }
  }
}
