                    "enableEnv": { "type": "string", "const": "CLAUDE_CODE_ENABLE_TELEMETRY" },
                    "metricsExporterEnv": { "type": "string", "const": "OTEL_METRICS_EXPORTER" },
                    "logsExporterEnv": { "type": "string", "const": "OTEL_LOGS_EXPORTER" },
                    "tracesBetaEnv": { "type": "string", "const": "CLAUDE_CODE_ENHANCED_TELEMETRY_BETA" },
                    "serviceName": { "type": "string", "const": "claude-code" },
                    "roiGuideUrl": { "type": "string" },
