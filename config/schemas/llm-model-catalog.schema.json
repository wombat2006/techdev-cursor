              "claude-code-auto-mode-environment",
              "claude-code-auto-mode-rules",
              "claude-code-auto-mode-inspect",
              "claude-code-monitoring-otel-setup",
              "claude-code-monitoring-metrics",
              "claude-code-monitoring-events-audit",
              "claude-code-monitoring-traces",
              "claude-code-monitoring-privacy",
              "context-window-management",
              "context-awareness",
              "context-window-overflow"
