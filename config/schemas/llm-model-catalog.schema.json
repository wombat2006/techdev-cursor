                  }
                },
                "notes": { "type": "string" }
              }
            },
            "notes": { "type": "string" }
          }
        },
        "contextAwareness": {
          "type": "object",
          "additionalProperties": false,
          "description": "Token budget signals in prompt — see ANTHROPIC_CONTEXT_WINDOW.md",
          "properties": {
