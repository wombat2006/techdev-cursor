          }
        },
        "notes": { "type": "string" }
      }
    },
    "paramSupport": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "supported": { "type": "boolean" },
        "values": {
          "type": "array",
          "items": { "type": "string" }
        },
        "default": { "type": "string" }
      }
    },
    "apiFeatures": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "supportedEndpoints": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["responses_api", "chat_completions", "realtime_api", "cli_only"]
          }
        },
        "recommendedEndpoint": {
          "type": "string",
          "enum": ["responses_api", "chat_completions", "realtime_api", "cli_only"]
        },
        "reasoningEffort": { "$ref": "#/$defs/paramSupport" },
        "verbosity": { "$ref": "#/$defs/paramSupport" },
        "structuredOutputs": { "type": "boolean" },
        "reasoningItems": {
          "type": "boolean",
          "description": "Responses API reasoning items stream (cookbook: reasoning-items)"
        },
        "promptCaching": {
          "type": "object",
          "additionalProperties": false,
          "description": "Anthropic prompt caching — see ANTHROPIC_PROMPT_CACHING.md",
          "properties": {
            "supported": { "type": "boolean" },
            "maxTtlHours": { "type": "number", "minimum": 0 },
            "minCacheTokens": { "type": "integer", "minimum": 1 },
            "automaticCaching": { "type": "boolean" },
            "explicitBreakpointsMax": {
              "type": "integer",
              "const": 4
            },
            "notes": { "type": "string" }
          }
        },
        "parallelToolCalls": {
          "type": "boolean",
          "description": "Provider supports multiple tool_use blocks per assistant turn — Anthropic: see ANTHROPIC_PARALLEL_TOOL_USE.md; OpenAI: Responses parallel tools"
        },
        "messageStreaming": {
          "type": "object",
          "additionalProperties": false,
          "description": "Messages API SSE streaming — see ANTHROPIC_MESSAGE_STREAMING.md",
          "properties": {
            "supported": { "type": "boolean" },
            "protocol": {
              "type": "string",
              "enum": ["sse"]
            },
            "notes": { "type": "string" }
          }
        },
        "programmaticToolCalling": {
          "type": "object",
          "additionalProperties": false,
          "description": "Code execution sandbox tool calls — see ANTHROPIC_PROGRAMMATIC_TOOL_CALLING.md",
          "properties": {
            "supported": { "type": "boolean" },
            "codeExecutionType": {
              "type": "string",
              "const": "code_execution_20260120"
            },
            "zdrEligible": { "type": "boolean" },
            "notes": { "type": "string" }
          }
        },
        "midConversationSystemMessages": {
          "type": "object",
          "additionalProperties": false,
          "description": "role: system in messages array — see ANTHROPIC_MID_CONVERSATION_SYSTEM_MESSAGES.md",
          "properties": {
            "supported": { "type": "boolean" },
            "platformModelMin": { "type": "string" },
            "zdrEligible": { "type": "boolean" },
            "notes": { "type": "string" }
          }
        },
        "tokenCounting": {
          "type": "object",
          "additionalProperties": false,
          "description": "messages/count_tokens preflight — see ANTHROPIC_TOKEN_COUNTING.md",
          "properties": {
            "supported": { "type": "boolean" },
            "endpoint": {
              "type": "string",
              "const": "messages/count_tokens"
            },
            "zdrEligible": { "type": "boolean" },
            "notes": { "type": "string" }
          }
        },
        "pdfSupport": {
          "type": "object",
          "additionalProperties": false,
          "description": "PDF document blocks — see ANTHROPIC_PDF_SUPPORT.md",
          "properties": {
            "supported": { "type": "boolean" },
            "zdrEligible": { "type": "boolean" },
            "maxRequestSizeMb": { "type": "number", "minimum": 1 },
            "maxPages": { "type": "integer", "minimum": 1 },
            "maxPages100kContext": { "type": "integer", "minimum": 1 },
            "sourceTypes": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": ["url", "base64", "file"]
              }
            },
            "filesApiBeta": { "type": "string" },
            "notes": { "type": "string" }
          }
        },
        "visionSupport": {
          "type": "object",
          "additionalProperties": false,
          "description": "Image vision blocks — see ANTHROPIC_VISION.md",
          "properties": {
            "supported": { "type": "boolean" },
            "zdrEligible": { "type": "boolean" },
            "maxImagesPerRequest200k": { "type": "integer", "minimum": 1 },
            "maxImagesPerRequestDefault": { "type": "integer", "minimum": 1 },
            "maxImageSizeMb": { "type": "number", "minimum": 1 },
            "maxImageDimensionPx": { "type": "integer", "minimum": 1 },
            "maxEdgePx": { "type": "integer", "minimum": 1 },
            "maxVisualTokens": { "type": "integer", "minimum": 1 },
            "highResolution": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "supported": { "type": "boolean" },
                "platformModelMin": { "type": "string" },
                "maxEdgePx": { "type": "integer", "minimum": 1 },
                "maxVisualTokens": { "type": "integer", "minimum": 1 }
              }
            },
            "sourceTypes": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": ["url", "base64", "file"]
              }
            },
            "mediaTypes": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": [
                  "image/jpeg",
                  "image/png",
                  "image/gif",
                  "image/webp"
                ]
              }
            },
            "filesApiBeta": { "type": "string" },
            "notes": { "type": "string" }
          }
        },
        "freeFormFunctionCalling": { "type": "boolean" },
        "contextFreeGrammar": { "type": "boolean" },
        "skillsApi": { "type": "boolean" },
        "goals": {
          "type": "boolean",
          "description": "Codex Goals — persistent evidence-checked outcomes (cookbook: using-goals-in-codex)"
        },
        "adaptiveReasoning": {
          "type": "boolean",
          "description": "Codex auto-adjusts reasoning depth by task complexity"
        },
        "assistantPhase": {
          "type": "object",
          "additionalProperties": false,
          "description": "Responses API assistant-item phase (GPT-5.4+ streaming / replay)",
          "properties": {
            "supported": { "type": "boolean" },
            "values": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": ["commentary", "final_answer"]
              }
            }
          }
        },
        "batchApi": {
          "type": "object",
          "additionalProperties": false,
          "description": "Async Message/Batch API — offline bulk only (OpenAI Batch API, Anthropic Message Batches); not sync batch_size parallelism",
          "properties": {
            "supported": { "type": "boolean" },
            "notes": { "type": "string" }
          }
        },
        "extendedThinking": {
          "type": "object",
          "additionalProperties": false,
          "description": "Anthropic extended / adaptive thinking — see ANTHROPIC_EXTENDED_THINKING.md · ANTHROPIC_ADAPTIVE_THINKING.md",
          "properties": {
            "supported": { "type": "boolean" },
            "preferredMode": {
              "type": "string",
              "enum": ["manual_enabled", "adaptive", "always_on"]
            },
            "interleavedBetaHeader": { "type": "string" },
            "blockPreservation": {
              "type": "string",
              "enum": ["last_turn_only", "all_turns"]
            },
            "displayDefault": {
              "type": "string",
              "enum": ["summarized", "omitted"]
            },
            "notes": { "type": "string" }
          }
        },
        "fineGrainedToolStreaming": {
          "type": "object",
          "additionalProperties": false,
          "description": "Anthropic eager_input_streaming on tools — see ANTHROPIC_FINE_GRAINED_TOOL_STREAMING.md",
          "properties": {
            "supported": { "type": "boolean" },
            "toolFlag": {
              "type": "string",
              "const": "eager_input_streaming"
            },
            "requiresStream": { "type": "boolean" },
            "notes": { "type": "string" }
          }
        },
        "agentSkills": {
          "type": "object",
          "additionalProperties": false,
          "description": "Anthropic Agent Skills — see ANTHROPIC_AGENT_SKILLS.md · ANTHROPIC_SKILLS_AUTHORING.md",
          "properties": {
            "supported": { "type": "boolean" },
            "zdrEligible": { "type": "boolean" },
            "skillMdMaxLines": { "type": "integer", "minimum": 1 },
            "preBuiltSkillIds": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": ["pptx", "xlsx", "docx", "pdf"]
              }
            },
            "betaHeaders": {
              "type": "array",
              "uniqueItems": true,
              "items": { "type": "string" }
            },
            "skillsApiEndpoint": {
              "type": "string",
              "const": "/v1/skills"
            },
            "requiresCodeExecution": { "type": "boolean" },
            "requiresFilesApi": { "type": "boolean" },
            "claudeCode": {
              "type": "object",
              "additionalProperties": false,
              "description": "Claude Code client surface — see CLAUDE_CODE_MONITORING.md · CLAUDE_CODE_AUTO_MODE.md · CLAUDE_CODE_GLOSSARY.md · CLAUDE_CODE_CLI_REFERENCE.md · CLAUDE_CODE_BEST_PRACTICES.md · CLAUDE_CODE_SKILLS.md · CLAUDE_CODE_MCP_CONNECT.md · CLAUDE_CODE_HOOKS.md · CLAUDE_CODE_DEBUG.md · CLAUDE_CODE_COST_MANAGEMENT.md · CLAUDE_CODE_PLUGINS.md · CLAUDE_CODE_SCHEDULED_TASKS.md · CLAUDE_CODE_PROGRAMMATIC.md · CLAUDE_CODE_DEEP_LINKS.md",
              "properties": {
                "supported": { "type": "boolean" },
                "openStandardUrl": { "type": "string" },
                "personalSkillsPath": { "type": "string" },
                "projectSkillsPath": { "type": "string" },
                "legacyCommandsPath": { "type": "string" },
                "minVersionBundledRun": { "type": "string" },
                "mcp": {
                  "type": "object",
                  "additionalProperties": false,
                  "description": "MCP client config — see CLAUDE_CODE_MCP_CONNECT.md",
                  "properties": {
                    "supported": { "type": "boolean" },
                    "userConfigPath": { "type": "string" },
                    "projectConfigFile": { "type": "string" },
                    "defaultStartupTimeoutMs": { "type": "integer", "minimum": 1 },
                    "sessionManageCommand": { "type": "string", "const": "/mcp" },
                    "notes": { "type": "string" }
                  }
                },
                "hooks": {
                  "type": "object",
                  "additionalProperties": false,
                  "description": "Lifecycle hooks — see CLAUDE_CODE_HOOKS.md",
                  "properties": {
                    "supported": { "type": "boolean" },
                    "userSettingsPath": { "type": "string" },
                    "projectSettingsPath": { "type": "string" },
                    "projectLocalSettingsPath": { "type": "string" },
                    "hooksScriptsPath": { "type": "string" },
                    "browseCommand": { "type": "string", "const": "/hooks" },
                    "minVersionIfField": { "type": "string" },
                    "notes": { "type": "string" }
                  }
                },
                "debug": {
                  "type": "object",
                  "additionalProperties": false,
                  "description": "Configuration diagnostics — see CLAUDE_CODE_DEBUG.md",
                  "properties": {
                    "supported": { "type": "boolean" },
                    "contextCommand": { "type": "string", "const": "/context" },
                    "doctorCommand": { "type": "string", "const": "/doctor" },
                    "statusCommand": { "type": "string", "const": "/status" },
                    "safeModeFlag": { "type": "string", "const": "--safe-mode" },
                    "minVersionSafeMode": { "type": "string" },
                    "cleanConfigEnvVar": { "type": "string", "const": "CLAUDE_CONFIG_DIR" },
                    "notes": { "type": "string" }
                  }
                },
                "costManagement": {
                  "type": "object",
                  "additionalProperties": false,
                  "description": "Token cost tracking and reduction — see CLAUDE_CODE_COST_MANAGEMENT.md",
                  "properties": {
                    "supported": { "type": "boolean" },
                    "usageCommand": { "type": "string", "const": "/usage" },
                    "usageCreditsCommand": { "type": "string", "const": "/usage-credits" },
                    "platformUrl": { "type": "string" },
                    "minVersionUsageBreakdown": { "type": "string" },
