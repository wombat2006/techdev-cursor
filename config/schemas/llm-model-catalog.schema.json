              "prompt-caching-1h-ttl",
              "prompt-caching-pre-warm",
              "prompt-caching-usage-fields",
              "prompt-caching-invalidation",
              "anthropic-pricing-catalog-as-is",
              "anthropic-pricing-prompt-caching-multipliers",
              "anthropic-pricing-batch-discount",
              "anthropic-pricing-tool-features",
              "anthropic-pricing-cloud-billing",
              "anthropic-models-overview-current-tier",
              "anthropic-models-overview-lineup",
              "anthropic-models-overview-version-policy",
              "anthropic-models-overview-id-versioning",
              "anthropic-models-overview-fable-mythos",
              "anthropic-models-overview-migration",
              "anthropic-system-cards-index",
              "anthropic-system-cards-catalog-as-is",
              "anthropic-system-cards-migration-tier",
              "mid-conversation-system-message",
              "mid-conversation-placement",
              "mid-conversation-prompt-caching",
              "mid-conversation-tool-relay",
              "token-counting-api",
              "token-counting-tools-modality",
              "token-counting-extended-thinking",
              "token-counting-vs-prompt-cache",
              "token-counting-rate-limits",
              "parallel-tool-use",
              "parallel-tool-result-batching",
              "parallel-tool-prompting",
              "fine-grained-tool-streaming",
              "tool-input-json-delta",
              "skills-authoring-best-practices",
              "skills-progressive-disclosure",
              "skills-executable-scripts",
              "skills-api-container",
              "skills-prebuilt-office-pdf",
              "skills-security-audit",
              "skills-surface-constraints",
              "claude-code-skills-layout",
              "claude-code-skills-frontmatter",
              "claude-code-skills-shell-injection",
              "claude-code-skills-subagent-fork",
