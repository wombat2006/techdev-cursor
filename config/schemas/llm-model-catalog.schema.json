                    "minVersion": { "type": "string" },
                    "maxPromptChars": { "type": "integer", "minimum": 1 },
                    "queryParams": {
                      "type": "array",
                      "items": { "type": "string", "enum": ["q", "cwd", "repo"] }
                    },
                    "vscodeOpenUrl": { "type": "string" },
                    "disableSettingKey": { "type": "string", "const": "disableDeepLinkRegistration" },
                    "notes": { "type": "string" }
                  }
                },
                "bestPractices": {
                  "type": "object",
                  "additionalProperties": false,
                  "description": "Workflow synthesis — see CLAUDE_CODE_BEST_PRACTICES.md",
