{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://techsapo.dev/schemas/llm-model-catalog.schema.json",
  "title": "LlmModelCatalog",
  "description": "Multi-vendor LLM model capability catalog (TS-21). Static traits — not per-request InferenceProfile.",
  "type": "object",
  "required": ["version", "vendors", "models"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+$"
    },
    "vendors": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/vendor"
      }
    },
    "models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/modelEntry"
      }
    },
    "aliases": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "cookbookIndex": {
      "type": "object",
      "description": "Optional reverse index: OpenAI Cookbook slug → model id[]",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "promptGuidanceIndex": {
      "type": "object",
      "description": "Optional reverse index: platform prompt-guidance topic slug → model id[]",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  },
  "$defs": {
    "vendor": {
      "type": "object",
      "required": ["displayName", "billingModel"],
      "additionalProperties": false,
      "properties": {
        "displayName": { "type": "string" },
        "billingModel": {
          "type": "string",
          "enum": ["subscription_cli", "api_key", "oauth_cli", "mixed"]
        },
        "docsUrl": { "type": "string", "format": "uri" },
        "cookbookUrl": {
          "type": "string",
          "format": "uri",
          "description": "Vendor cookbook root (e.g. https://cookbook.openai.com)"
        },
        "systemCardsUrl": {
          "type": "string",
          "format": "uri",
          "description": "Model system cards index — see ANTHROPIC_MODEL_SYSTEM_CARDS.md"
        }
      }
    },
    "reference": {
      "type": "object",
      "required": ["type", "url"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["cookbook", "platform_docs", "pricing", "adr", "system_card"]
        },
        "title": { "type": "string" },
        "slug": {
          "type": "string",
          "description": "Cookbook registry slug (registry.yaml)"
        },
        "url": { "type": "string", "format": "uri" },
        "lastReviewed": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "modality": {
      "type": "string",
      "enum": ["text", "vision", "document", "audio", "multimodal"]
    },
    "promptingProfile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "style": {
          "type": "string",
          "enum": ["minimal", "balanced", "structured", "agentic", "orchestrator"]
        },
        "approach": {
          "type": "string",
          "enum": [
            "outcome_first",
            "minimal",
            "balanced",
            "process_heavy_legacy",
            "orchestrator",
            "agentic_long_horizon",
            "fast"
          ],
          "description": "Platform prompt guidance: GPT-5.5 outcome_first; Codex minimal; Anthropic orchestrator / agentic_long_horizon / fast"
        },
        "platformGuideUrl": {
          "type": "string",
          "format": "uri",
          "description": "Per-model prompt guidance MD (e.g. …/prompt-guidance/gpt-5.4.md)"
        },
        "platformGuideModel": {
          "type": "string",
          "description": "Content-switcher value on prompt-guidance page (e.g. gpt-5.4, gpt-5.3-codex)"
        },
        "guidanceTopics": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "personality-behavior",
              "preamble-streaming",
              "outcome-first-stopping",
              "formatting-verbosity",
              "retrieval-budget-citations",
              "creative-guardrails",
              "frontend-quality",
              "validation-loops",
              "assistant-phase",
              "output-contract",
              "follow-through-policy",
              "instruction-priority",
              "missing-context-gating",
              "tool-persistence",
              "codex-autonomy",
              "avoid-upfront-preamble",
              "phase-required",
              "compaction-guidance",
              "context-gathering-batch",
              "hub-peer-messaging",
              "subagent-lifecycle",
              "extended-thinking-tool-use",
              "preserve-thinking-blocks",
              "context-compaction",
              "tool-result-clearing",
              "memory-tool-cross-session",
              "skills-document-generation",
              "contextual-embeddings-rag",
              "batch-api-offline",
              "structured-json-tool-use",
              "web-page-summarization",
              "json-mode-prefill",
              "multi-document-react-agents",
              "pdf-document-blocks",
              "pdf-source-url-base64-file",
              "pdf-limits-chunking",
              "pdf-caching-batch",
              "vision-image-blocks",
              "vision-source-url-base64-file",
              "vision-limits-token-cost",
              "vision-prompt-placement",
              "vision-coordinates-bounding-box",
              "vision-multi-image-comparison",
              "vision-high-resolution-migration",
              "iterative-search-tool-use",
              "rag-summary-indexing-reranking",
              "interleaved-thinking-beta",
              "thinking-display-omitted",
              "adaptive-thinking-migration",
              "adaptive-thinking",
              "adaptive-thinking-effort",
              "thinking-prompt-steering",
              "thinking-mode-cache-invalidation",
              "multilingual-prompting",
              "multilingual-native-script",
              "multilingual-japanese",
              "message-streaming-sse",
              "streaming-thinking-delta",
              "streaming-error-recovery",
              "streaming-final-message",
              "programmatic-tool-calling",
              "allowed-callers-field",
              "programmatic-container-lifecycle",
