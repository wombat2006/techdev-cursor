                  }
                },
                "autoMode": {
                  "type": "object",
                  "additionalProperties": false,
                  "description": "Auto mode classifier config — see CLAUDE_CODE_AUTO_MODE.md",
                  "properties": {
                    "supported": { "type": "boolean" },
                    "platformUrl": { "type": "string" },
                    "permissionModesUrl": { "type": "string" },
                    "defaultsSubcommand": { "type": "string", "const": "claude auto-mode defaults" },
                    "configSubcommand": { "type": "string", "const": "claude auto-mode config" },
                    "critiqueSubcommand": { "type": "string", "const": "claude auto-mode critique" },
                    "bedrockEnableEnv": { "type": "string", "const": "CLAUDE_CODE_ENABLE_AUTO_MODE" },
                    "notes": { "type": "string" }
                  }
                },
                "monitoring": {
                  "type": "object",
