{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://techsapo.dev/schemas/llm-model-catalog.schema.json",
  "title": "LlmModelCatalog",
  "description": "Multi-vendor LLM model capability catalog (TS-21). Static traits — not per-request InferenceProfile.",
  "type": "object",
  "required": ["version", "vendors", "models"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+$"
    },
    "vendors": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/vendor"
      }
    },
    "models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/modelEntry"
      }
    },
    "aliases": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "cookbookIndex": {
      "type": "object",
      "description": "Optional reverse index: OpenAI Cookbook slug → model id[]",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  },
  "$defs": {
    "vendor": {
      "type": "object",
      "required": ["displayName", "billingModel"],
      "additionalProperties": false,
      "properties": {
        "displayName": { "type": "string" },
        "billingModel": {
          "type": "string",
          "enum": ["subscription_cli", "api_key", "oauth_cli", "mixed"]
        },
        "docsUrl": { "type": "string", "format": "uri" },
        "cookbookUrl": {
          "type": "string",
          "format": "uri",
          "description": "Vendor cookbook root (e.g. https://cookbook.openai.com)"
        }
      }
    },
    "reference": {
      "type": "object",
      "required": ["type", "url"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["cookbook", "platform_docs", "pricing", "adr"]
        },
        "title": { "type": "string" },
        "slug": {
          "type": "string",
          "description": "Cookbook registry slug (registry.yaml)"
        },
        "url": { "type": "string", "format": "uri" },
        "lastReviewed": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "modality": {
      "type": "string",
      "enum": ["text", "vision", "document", "audio", "multimodal"]
    },
    "promptingProfile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "style": {
          "type": "string",
          "enum": ["minimal", "balanced", "structured", "agentic"]
        },
        "notes": { "type": "string" }
      }
    },
    "paramSupport": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "supported": { "type": "boolean" },
        "values": {
          "type": "array",
          "items": { "type": "string" }
        },
        "default": { "type": "string" }
      }
    },
    "apiFeatures": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "supportedEndpoints": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["responses_api", "chat_completions", "realtime_api", "cli_only"]
          }
        },
        "recommendedEndpoint": {
          "type": "string",
          "enum": ["responses_api", "chat_completions", "realtime_api", "cli_only"]
        },
        "reasoningEffort": { "$ref": "#/$defs/paramSupport" },
        "verbosity": { "$ref": "#/$defs/paramSupport" },
        "structuredOutputs": { "type": "boolean" },
        "reasoningItems": {
          "type": "boolean",
          "description": "Responses API reasoning items stream (cookbook: reasoning-items)"
        },
        "promptCaching": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "supported": { "type": "boolean" },
            "maxTtlHours": { "type": "number", "minimum": 0 },
            "notes": { "type": "string" }
          }
        },
        "parallelToolCalls": { "type": "boolean" },
        "freeFormFunctionCalling": { "type": "boolean" },
        "contextFreeGrammar": { "type": "boolean" },
        "skillsApi": { "type": "boolean" },
        "goals": {
          "type": "boolean",
          "description": "Codex Goals — persistent evidence-checked outcomes (cookbook: using-goals-in-codex)"
        },
        "adaptiveReasoning": {
          "type": "boolean",
          "description": "Codex auto-adjusts reasoning depth by task complexity"
        }
      }
    },
    "builtinTools": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mcp": { "type": "boolean" },
        "computerUse": { "type": "boolean" },
        "webSearch": { "type": "boolean" },
        "fileSearch": { "type": "boolean" },
        "codeInterpreter": { "type": "boolean" },
        "customTool": { "type": "boolean" },
        "terminal": { "type": "boolean" },
        "applyPatch": { "type": "boolean" }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reasoning": {
          "type": "string",
          "enum": ["minimal", "low", "medium", "high", "frontier"]
        },
        "toolUse": { "type": "boolean" },
        "toolSearch": { "type": "boolean" },
        "computerUse": { "type": "boolean" },
        "compaction": { "type": "boolean" },
        "multimodal": { "type": "boolean" },
        "japaneseQuality": {
          "type": "string",
          "enum": ["unknown", "fair", "good", "excellent"]
        },
        "codegen": { "type": "boolean" },
        "longWorkflow": { "type": "boolean" },
        "spatialReasoning": { "type": "boolean" },
        "documentUnderstanding": { "type": "boolean" }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contextTokens": { "type": "integer", "minimum": 1 },
        "maxOutputTokens": { "type": "integer", "minimum": 1 }
      }
    },
    "transport": {
      "type": "object",
      "required": ["invocationTypes"],
      "additionalProperties": false,
      "properties": {
        "invocationTypes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["claude_cli", "codex_cli", "agy_cli", "responses_api", "openai_sdk", "anthropic_sdk", "openrouter"]
          }
        },
        "preferredInvocation": {
          "type": "string",
          "enum": ["claude_cli", "codex_cli", "agy_cli", "responses_api", "openai_sdk", "anthropic_sdk", "openrouter"]
        },
        "apiSurface": {
          "type": "string",
          "enum": ["responses_api", "chat_completions", "cli_only"]
        },
        "nativeModelFlag": {
          "type": "string",
          "description": "CLI/API model id only (e.g. gpt-5.5, sonnet) — not full invocation recipe"
        },
        "invocationBindingRef": {
          "type": "string",
          "description": "Optional pointer to adapter binding implementation (e.g. openai:codex-exec-v1). Args/body live in code, not catalog."
        }
      }
    },
    "modelEntry": {
      "type": "object",
      "required": ["id", "vendor", "displayName", "status", "tier", "capabilities", "transport"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "vendor": { "type": "string", "minLength": 1 },
        "modelFamily": {
          "type": "string",
          "description": "Vendor model generation line (gpt-5.5, gpt-5.4, gpt-5-codex, claude-sonnet-4, …)"
        },
        "displayName": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["active", "planned", "deprecated"]
        },
        "replaces": { "type": "string" },
        "deprecatedBy": { "type": "string" },
        "tier": { "type": "number", "minimum": 0, "maximum": 5 },
        "roles": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "llm_analyze",
              "llm_codegen",
              "llm_agent_edit",
              "llm_cross_critique",
              "llm_aggregate",
              "grounding_fetch",
              "embedding"
            ]
          }
        },
        "modalities": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/modality" }
        },
        "presetDefault": {
          "type": "string",
          "enum": ["fast", "balanced", "deep", "critical"]
        },
        "prompting": { "$ref": "#/$defs/promptingProfile" },
        "capabilities": { "$ref": "#/$defs/capabilities" },
        "builtinTools": { "$ref": "#/$defs/builtinTools" },
        "apiFeatures": { "$ref": "#/$defs/apiFeatures" },
        "limits": { "$ref": "#/$defs/limits" },
        "transport": { "$ref": "#/$defs/transport" },
        "references": {
          "type": "array",
          "items": { "$ref": "#/$defs/reference" }
        },
        "costHint": {
          "type": "string",
          "enum": ["nano", "mini", "standard", "flagship", "frontier"]
        },
        "notes": { "type": "string" }
      }
    }
  }
}
