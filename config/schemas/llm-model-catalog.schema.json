                    "notes": { "type": "string" }
                  }
                },
                "cliReference": {
                  "type": "object",
                  "additionalProperties": false,
                  "description": "CLI commands and flags — see CLAUDE_CODE_CLI_REFERENCE.md",
                  "properties": {
                    "supported": { "type": "boolean" },
                    "platformUrl": { "type": "string" },
