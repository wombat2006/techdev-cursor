                    },
                    "stdinMaxMb": { "type": "integer", "minimum": 1 },
                    "minVersionStdinCap": { "type": "string" },
                    "minVersionBgGrace": { "type": "string" },
                    "minVersionBgWaitCeiling": { "type": "string" },
                    "bgWaitCeilingEnvVar": { "type": "string", "const": "CLAUDE_CODE_PRINT_BG_WAIT_CEILING_MS" },
                    "agentSdkOverviewUrl": { "type": "string" },
                    "notes": { "type": "string" }
                  }
                },
                "deepLinks": {
                  "type": "object",
                  "additionalProperties": false,
                  "description": "claude-cli:// deep links — see CLAUDE_CODE_DEEP_LINKS.md",
                  "properties": {
                    "supported": { "type": "boolean" },
                    "urlScheme": { "type": "string", "const": "claude-cli" },
