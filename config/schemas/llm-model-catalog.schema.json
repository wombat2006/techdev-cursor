              "claude-code-mcp-oauth-auth",
              "claude-code-mcp-troubleshooting",
              "claude-code-hooks-events",
              "claude-code-hooks-command-io",
              "claude-code-hooks-matchers",
              "claude-code-hooks-compaction",
              "claude-code-hooks-permissions",
              "claude-code-debug-context-commands",
              "claude-code-debug-settings-scope",
              "claude-code-debug-isolation",
              "claude-code-debug-common-causes",
              "claude-code-cost-usage-tracking",
              "claude-code-cost-context-management",
              "claude-code-cost-model-mcp",
              "claude-code-cost-hooks-skills",
              "claude-code-cost-thinking-teams",
              "claude-code-plugins-marketplaces",
              "claude-code-plugins-install-scopes",
              "claude-code-plugins-code-intelligence",
