{
  "version": "1.0.0",
  "project_root": "..",
  "morphology": {
    "backend": "fugashi",
    "dictionary": "unidic-lite",
    "required": true
  },
  "corpus": {
    "description": "In-repo platform docs (interim until Google Drive local mirror path is set)",
    "files": [
      "AGENTS.md",
      "README.md",
      "docs/WALL_BOUNCE_SYSTEM.md",
      "docs/ARCHITECTURE.md",
      "docs/MCP_SERVICES.md",
      "docs/RAG_SETUP_GUIDE.md",
      "docs/ANTIGRAVITY_CLI_MIGRATION.md",
      "docs/PROVIDER_INTEGRATION_BACKLOG.md",
      "docs/FORK_CURSOR.md",
      "docs/DEVELOPMENT_GUIDE.md",
      "meta/TO-BE-GLOSSARY-PIPELINE.md"
    ]
  },
  "reference_catalogs": [
    "config/fork/devassist-dictionary-v0.json",
    "README.md",
    "AGENTS.md"
  ],
  "filter": {
    "seed_first": true,
    "min_morph_freq": 3,
    "min_chapters": 2,
    "max_candidates_output": 100,
    "emit_reject": false
  },
  "knowledge_filter": {
    "enabled": false,
    "mcp_server": "glossary-knowledge",
    "transport": "stdio",
    "domain": "devassist-platform",
    "batch_size": 50
  },
  "output": {
    "registry": "meta/glossary-registry.json",
    "adopt": "meta/glossary-adopt.json",
    "hold": "meta/glossary-hold.json",
    "reject": "build/glossary/reject.jsonl"
  },
  "scoring": {
    "adopt_threshold": 4,
    "hold_threshold": 2,
    "weights": {
      "in_ts_or_adr": 2,
      "multi_chapter": 2,
      "emphasis": 2,
      "english_pair": 2,
      "already_in_glossary": -10,
      "stop_noun": -5
    }
  },
  "stop_nouns": ["こと", "もの", "設定", "機能", "方法", "場合"],
  "stop_english": ["The", "API", "Config", "Type", "String", "Boolean"],
  "manual_adopt": [
    "Wall-Bounce",
    "MCP",
    "Model Context Protocol",
    "RAG",
    "DevAssist",
    "TechSapo",
    "Cursor",
    "Google Drive"
  ],
  "manual_reject": []
}
