{
  "mcpServers": {
    "glossary-knowledge": {
      "command": "../term-prep-platform/.venv/bin/python",
      "args": [
        "-m",
        "glossary_knowledge_mcp"
      ],
      "cwd": "../term-prep-platform/mcp/glossary-knowledge",
      "env": {
        "PYTHONPATH": "../term-prep-platform/mcp/glossary-knowledge"
      }
    },
    "techsapo-providers": {
      "command": "/home/wombat/.nvm/versions/node/v22.22.3/bin/node",
      "args": [
        "/home/wombat/techdev-cursor/dist/services/techsapo-providers-mcp-server.js"
      ],
      "cwd": "/home/wombat/techdev-cursor"
    },
    "serena": {
      "command": "/home/wombat/.local/bin/uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--transport",
        "stdio",
        "--context",
        "ide",
        "--project",
        "/home/wombat/techdev-cursor"
      ]
    },
    "brv": {
      "command": "/home/wombat/techdev-cursor/node_modules/.bin/brv",
      "args": [
        "mcp"
      ],
      "cwd": "/home/wombat/techdev-cursor"
    }
  }
}
