# API Keys and Secrets (additional security)
**/secrets/
**/*secret*
config/secrets.json
config/keys.json
# 証明書・秘密鍵（*.key は下の Certificate files でカバー）
# 注意: **/*key* は monkey-patch.ts 等を誤除外するため使用しない

# MCP Configuration (may contain sensitive data)
config/cursor-mcp.json
.cursor/mcp.json
# リポジトリ外パス — git では無効だが意図のメモとして残す
# ~/.codex/
# ~/.claude.json

# OAuth / API credential files (use .env — see .env.example)
credentials.json
google-credentials.json
config/credentials.json
token.json
**/token.json

# Test fixtures & generated test output (tests/*.ts stays tracked)
tests/fixtures/
test-results/
playwright-report/
playwright/.cache/
*-test-results.json

# OpenAI Batch API JSONL (prompts / bulk request bodies — local only)
*.jsonl

# Glossary pipeline (Phase 0 — legacy single-file output deprecated)
meta/glossary-candidates.json

# Local configuration overrides
config/local.json
config/development.json
config/production.json

