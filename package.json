{
  "name": "techdev-cursor",
  "version": "1.0.0",
  "description": "TechSapo DevAssist — Cursor MCP primary fork (unified provider MCP)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && npm run build:copy-config",
    "build:copy-config": "mkdir -p dist/config && cp src/config/*.json dist/config/",
    "start": "npm run pm2:start",
    "start:legacy": "npm run start:with-codex",
    "start:app": "node dist/index.js",
    "start:with-codex": "./scripts/start-with-codex-mcp.sh",
    "stop": "npm run pm2:stop",
    "stop:legacy": "./scripts/stop-services.sh",
    "pm2:start": "bash scripts/pm2-start.sh",
    "pm2:start:all": "bash scripts/pm2-start-all.sh",
    "pm2:stop": "bash scripts/pm2-stop.sh",
    "pm2:restart": "npm run pm2:stop && npm run pm2:start",
    "pm2:status": "pm2 status || npx pm2 status",
    "pm2:logs": "pm2 logs || npx pm2 logs",
    "pm2:monit": "pm2 monit || npx pm2 monit",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint src/**/*.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "validate:config": "node scripts/validate-config.mjs",
    "fork-status:timestamp": "node scripts/fork-status-timestamp.mjs",
    "test:contract": "npm run validate:config && jest tests/adapters/catalog-resolver-drift.test.ts tests/adapters/adapter-spawn-contract.test.ts tests/adapters/adapter-preset-matrix-schema.test.ts tests/unit/simulated-provider-guard.test.ts tests/adapters/inference-profile-resolver.test.ts",
    "generate:proposal-pptx": "node scripts/pptx-gen/generate-proposal-pptx.mjs",
    "audit:tech-stack": "node scripts/audit-tech-stack.mjs",
    "cipher-mcp": "npx @byterover/cipher --mode mcp",
    "claude-code-mcp": "node dist/services/claude-code-mcp-server.js",
    "cipher-api": "npx @byterover/cipher --mode api --port 3002",
    "codex-mcp": "./scripts/start-codex-mcp.sh",
    "codex-mcp-stop": "./scripts/start-codex-mcp.sh -s",
    "codex-mcp-restart": "./scripts/start-codex-mcp.sh -r",
    "codex-mcp-test": "./scripts/start-codex-mcp.sh -t",
    "techsapo-providers-mcp": "node dist/services/techsapo-providers-mcp-server.js",
    "mcp:list-tools-smoke": "node scripts/mcp-list-tools-smoke.js",
    "g7:adapter-smoke": "node scripts/g7-adapter-smoke.js",
    "cursor-mcp:config": "node scripts/generate-cursor-mcp-config.mjs",
    "glossary:extract": "bash scripts/run-glossary-extract.sh",
    "glossary:extract:check": "bash scripts/run-glossary-extract.sh --check",
    "glossary:mcp-smoke": "bash scripts/glossary-mcp-smoke.sh",
    "mcp-performance": "node -e \"require('./dist/services/mcp-performance-monitor').mcpPerformanceMonitor.getPerformanceSummary()\"",
    "mcp-metrics": "node -e \"console.log(JSON.stringify(require('./dist/services/mcp-performance-monitor').mcpPerformanceMonitor.getLatestMetrics(), null, 2))\"",
    "mcp-alerts": "node -e \"console.log(JSON.stringify(require('./dist/services/mcp-performance-monitor').mcpPerformanceMonitor.getActiveAlerts(), null, 2))\"",
    "mcp-recommendations": "node -e \"console.log(JSON.stringify(require('./dist/services/mcp-performance-monitor').mcpPerformanceMonitor.getRecommendations(), null, 2))\"",
    "mcp-optimize": "npm run build && npm run mcp-performance && npm run mcp-recommendations"
  },
  "keywords": [
    "infrastructure",
    "support",
    "llm",
    "ai",
    "orchestrator",
    "mcp",
    "redis",
    "huggingface",
    "cipher",
    "techsapo",
    "rag",
    "googledrive",
    "openai",
    "wall-bounce"
  ],
  "author": "TechSapo Team",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.1",
    "@anthropic-ai/sdk": "^0.63.1",
    "@byterover/cipher": "^0.3.0",
    "@google/generative-ai": "^0.24.1",
    "@huggingface/hub": "^0.15.1",
    "@huggingface/inference": "^2.8.0",
    "@modelcontextprotocol/sdk": "^1.18.1",
    "@types/uuid": "^9.0.7",
    "@upstash/redis": "^1.35.3",
    "axios": "^1.18.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "google-auth-library": "^9.15.1",
    "googleapis": "^126.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "mysql2": "^3.6.5",
    "openai": "^4.104.0",
    "pptxgenjs": "^4.0.1",
    "prom-client": "^15.1.3",
    "redis": "^4.6.10",
    "sqlite3": "^6.0.1",
    "uuid": "^14.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.6",
    "@babel/plugin-syntax-typescript": "^7.27.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/ioredis-mock": "^8.2.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.10.4",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "babel-plugin-jest-hoist": "^30.0.1",
    "eslint": "^8.55.0",
    "ioredis-mock": "^8.13.0",
    "jest": "^29.7.0",
    "nock": "^14.0.10",
    "pm2": "^6.0.14",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "~5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "punycode": "npm:punycode@^2.3.1"
  },
  "resolutions": {
    "punycode": "^2.3.1"
  }
}
